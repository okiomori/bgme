{
	"terminal.integrated.defaultProfile.windows": "PowerShell",
	"files.associations": {
		"*.instructions.md": "markdown",
		"*.prompt.md": "markdown",
		"*.agent.md": "markdown"
	},
	"search.exclude": {
		"**/node_modules": true,
		"**/scripts/output/imagegen/**": true,
		"**/scripts/output/kra_extract/**": true
	},
	"files.watcherExclude": {
		"**/node_modules/**": true,
		"**/scripts/output/imagegen/**": true,
		"**/scripts/output/kra_extract/**": true
	},
	"liveServer.settings.port": 4175,
	"debug.javascript.autoAttachFilter": "smart"
}